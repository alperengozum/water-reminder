<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_streak_bg_warm"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/widget_streak_icon_bg_warm"
            android:gravity="center"
            android:text="🔥"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_streak_label"
                android:textColor="#B45309"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/widget_streak_preview_count"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:text="@string/widget_streak_unit_plural"
                    android:textColor="#334155"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_streak_preview_message"
                android:textColor="#92400E"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="7dp"
            android:paddingVertical="3dp"
            android:text="@string/widget_streak_preview_pct"
            android:textColor="#B45309"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 7-day progress bars: 5 filled, 2 empty (matches preview_count = 5) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <ImageView android:layout_width="0dp" android:layout_height="5dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/widget_streak_dot_filled_warm" />
        <ImageView android:layout_width="0dp" android:layout_height="5dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/widget_streak_dot_filled_warm" />
        <ImageView android:layout_width="0dp" android:layout_height="5dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/widget_streak_dot_filled_warm" />
        <ImageView android:layout_width="0dp" android:layout_height="5dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/widget_streak_dot_filled_warm" />
        <ImageView android:layout_width="0dp" android:layout_height="5dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/widget_streak_dot_filled_warm" />
        <ImageView android:layout_width="0dp" android:layout_height="5dp" android:layout_weight="1" android:layout_marginEnd="4dp" android:background="@drawable/widget_streak_dot_empty_warm" />
        <ImageView android:layout_width="0dp" android:layout_height="5dp" android:layout_weight="1" android:background="@drawable/widget_streak_dot_empty_warm" />
    </LinearLayout>


</LinearLayout>
