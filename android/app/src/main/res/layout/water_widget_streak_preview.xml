<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_streak_bg_warm"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp">

    <TextView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/widget_streak_icon_bg_warm"
        android:gravity="center"
        android:text="🔥"
        android:textSize="18sp" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/widget_streak_label"
            android:textColor="#B45309"
            android:textSize="9sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_streak_preview_count"
                android:textColor="@color/widget_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="@string/widget_streak_unit_plural"
                android:textColor="#334155"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_streak_preview_message"
            android:textColor="#92400E"
            android:textSize="10sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="@drawable/widget_streak_dot_filled_warm" />
            <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="@drawable/widget_streak_dot_filled_warm" />
            <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="@drawable/widget_streak_dot_filled_warm" />
            <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="@drawable/widget_streak_dot_filled_warm" />
            <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="@drawable/widget_streak_dot_filled_warm" />
            <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:layout_marginEnd="3dp" android:background="@drawable/widget_streak_dot_empty_warm" />
            <ImageView android:layout_width="0dp" android:layout_height="4dp" android:layout_weight="1" android:background="@drawable/widget_streak_dot_empty_warm" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:text="@string/widget_streak_preview_pct"
            android:textColor="#B45309"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>
