<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_streak_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_streak_bg"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingTop="12dp"
    android:paddingBottom="10dp">

    <!-- icon badge + text column -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/widget_streak_flame"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/widget_streak_icon_bg"
            android:gravity="center"
            android:text="🔥"
            android:textSize="20sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_streak_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_streak_label"
                android:textColor="#94A3B8"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/widget_streak_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/widget_text_primary"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_streak_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:text="@string/widget_streak_unit_plural"
                    android:textColor="#334155"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_streak_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#64748B"
                android:textSize="10sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_streak_pct"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="7dp"
            android:paddingVertical="3dp"
            android:textColor="#0E7490"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- 7-day streak progress bars -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_streak_dot_0"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_streak_dot_empty_cool" />

        <ImageView
            android:id="@+id/widget_streak_dot_1"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_streak_dot_empty_cool" />

        <ImageView
            android:id="@+id/widget_streak_dot_2"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_streak_dot_empty_cool" />

        <ImageView
            android:id="@+id/widget_streak_dot_3"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_streak_dot_empty_cool" />

        <ImageView
            android:id="@+id/widget_streak_dot_4"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_streak_dot_empty_cool" />

        <ImageView
            android:id="@+id/widget_streak_dot_5"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_streak_dot_empty_cool" />

        <ImageView
            android:id="@+id/widget_streak_dot_6"
            android:layout_width="0dp"
            android:layout_height="5dp"
            android:layout_weight="1"
            android:background="@drawable/widget_streak_dot_empty_cool" />
    </LinearLayout>


</LinearLayout>
